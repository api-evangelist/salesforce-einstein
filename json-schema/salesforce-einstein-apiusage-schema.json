{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ApiUsage",
  "title": "ApiUsage",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "startsAt": {
      "type": "string",
      "format": "date-time"
    },
    "endsAt": {
      "type": "string",
      "format": "date-time"
    },
    "plan": {
      "type": "object",
      "properties": {
        "planId": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "predictionsUsed": {
      "type": "integer"
    },
    "predictionsMax": {
      "type": "integer"
    },
    "object": {
      "type": "string"
    }
  }
}